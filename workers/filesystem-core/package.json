{
  "name": "@haimang/filesystem-core-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Pre-worker-matrix shell for filesystem-core",
  "scripts": {
    "prepare:package-manifest": "node ../../scripts/generate-package-manifest.mjs --worker filesystem-core --ts-module src/generated/package-manifest.ts",
    "prebuild": "pnpm run prepare:package-manifest && pnpm --filter @nano-agent/storage-topology build",
    "pretypecheck": "pnpm run prepare:package-manifest && pnpm --filter @nano-agent/storage-topology build",
    "pretest": "pnpm run prepare:package-manifest && pnpm --filter @nano-agent/storage-topology build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "predeploy": "node ../../scripts/verify-published-packages.mjs",
    "predeploy:preview": "pnpm run predeploy",
    "deploy:preview": "pnpm run predeploy && pnpm build && wrangler deploy --env preview",
    "deploy:production": "pnpm run predeploy && pnpm build && wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run --env=\"\""
  },
  "dependencies": {
    "@haimang/nacp-core": "workspace:*",
    "@haimang/nacp-session": "workspace:*",
    "@nano-agent/storage-topology": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.83.0"
  }
}
