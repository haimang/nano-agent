{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nano-agent-orchestrator-auth",
  "main": "dist/index.js",
  // ZX2 Phase 1 P1-02 (transport-profiles.md):
  // orchestrator-auth 仅暴露 RPC + /health；不应有 public business routes。
  // 显式关闭 workers.dev 公网入口（profile = nacp-internal + health-probe）。
  "workers_dev": false,
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  // Required deploy-time secrets:
  // - PASSWORD_SALT
  // - WECHAT_APPID
  // - WECHAT_SECRET
  // - JWT_SIGNING_KEY_<kid> (for example JWT_SIGNING_KEY_v1)
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview",
    "OWNER_TAG": "nano-agent",
    "WORKER_VERSION": "orchestrator-auth@preview",
    "JWT_SIGNING_KID": "v1",
    "WECHAT_API_BASE_URL": "https://api.weixin.qq.com/sns/jscode2session"
  },
  "d1_databases": [
    {
      "binding": "NANO_AGENT_DB",
      "database_name": "nano-agent-preview",
      // Shared `nano-agent-preview` D1 instance — same UUID across all 6 workers
      // so they read/write the same truth. Production deploys override per-env.
      "database_id": "421bf213-f3af-4d79-9de0-9cdb5e61e747"
    }
  ],
  "services": [
    { "binding": "ORCHESTRATOR_CORE", "service": "nano-agent-orchestrator-core" }
  ],
  // RH0 P0-C1 — KV/R2 binding first-declaration (placeholder ids).
  "kv_namespaces": [
    {
      "binding": "NANO_KV",
      "id": "f5de37a4139a480683368d39ca4bbb62"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NANO_R2",
      "bucket_name": "nano-agent-spike-do-storage-probe"
    }
  ],
  "env": {
    "preview": {
      "vars": {
        "ENVIRONMENT": "preview",
        "OWNER_TAG": "nano-agent",
        "WORKER_VERSION": "orchestrator-auth@preview",
        "JWT_SIGNING_KID": "v1",
        "WECHAT_API_BASE_URL": "https://api.weixin.qq.com/sns/jscode2session"
      },
      "d1_databases": [
        {
          "binding": "NANO_AGENT_DB",
          "database_name": "nano-agent-preview",
          // Shared `nano-agent-preview` D1 instance — see top-of-file comment.
          "database_id": "421bf213-f3af-4d79-9de0-9cdb5e61e747"
        }
      ],
      "services": [
        { "binding": "ORCHESTRATOR_CORE", "service": "nano-agent-orchestrator-core-preview" }
      ],
      "kv_namespaces": [
        {
          "binding": "NANO_KV",
          "id": "f5de37a4139a480683368d39ca4bbb62"
        }
      ],
      "r2_buckets": [
        {
          "binding": "NANO_R2",
          "bucket_name": "nano-agent-spike-do-storage-probe"
        }
      ]
    }
  }
}
