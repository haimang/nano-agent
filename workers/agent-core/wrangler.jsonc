{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nano-agent-agent-core",
  "main": "dist/index.js",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview",
    "OWNER_TAG": "nano-agent"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION_DO",
        "class_name": "NanoSessionDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["NanoSessionDO"]
    }
  ],
  // P2 Phase 4 (D07 activation): BASH_CORE service binding activated
  // — the downstream worker `nano-agent-bash-core-preview` is live
  // (P1.B Phase 5 deploy; Version ID 50335742-e9e9-4f49-b6d7-ec58e0d1cfb4).
  // CONTEXT_CORE / FILESYSTEM_CORE stay commented in first-wave runtime:
  // P3 / P4 absorb their code, but agent-core still keeps context/filesystem
  // on the host-local side until a later charter explicitly promotes them
  // to remote bindings.
  "services": [
    { "binding": "BASH_CORE", "service": "nano-agent-bash-core" }
    // { "binding": "CONTEXT_CORE", "service": "nano-agent-context-core" },
    // { "binding": "FILESYSTEM_CORE", "service": "nano-agent-filesystem-core" }
  ],
  "env": {
    "preview": {
      "vars": {
        "ENVIRONMENT": "preview",
        "OWNER_TAG": "nano-agent"
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "SESSION_DO",
            "class_name": "NanoSessionDO"
          }
        ]
      },
      "services": [
        { "binding": "BASH_CORE", "service": "nano-agent-bash-core-preview" }
      ]
    }
  }
}
