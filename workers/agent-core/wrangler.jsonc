{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nano-agent-agent-core",
  "main": "dist/index.js",
  // ZX2 Phase 1 P1-02 (transport-profiles.md):
  // agent-core 不是 public facade。preview 与 production 都关闭 workers.dev
  // 公网入口；本地调试经 wrangler dev 或 orchestrator-core facade。
  "workers_dev": false,
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview",
    "OWNER_TAG": "nano-agent",
    "WORKER_VERSION": "agent-core@preview",
    "TEAM_UUID": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
    "ORCHESTRATOR_PUBLIC_BASE_URL": "https://nano-agent-orchestrator-core-preview.haimang.workers.dev",
    "NANO_AGENT_LLM_CALL_LIMIT": "200",
    "NANO_AGENT_TOOL_CALL_LIMIT": "400"
    // NANO_AGENT_ALLOW_PREVIEW_TEAM_SEED is intentionally NOT set here so
    // production deployments do not auto-seed quota teams. It is only set in
    // the explicit preview env override below.
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION_DO",
        "class_name": "NanoSessionDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["NanoSessionDO"]
    }
  ],
  // P2 Phase 4 (D07 activation): BASH_CORE service binding activated
  // — the downstream worker `nano-agent-bash-core-preview` is live
  // (P1.B Phase 5 deploy; Version ID 50335742-e9e9-4f49-b6d7-ec58e0d1cfb4).
  // CONTEXT_CORE / FILESYSTEM_CORE stay commented in first-wave runtime:
  // P3 / P4 absorb their code, but agent-core still keeps context/filesystem
  // on the host-local side until a later charter explicitly promotes them
  // to remote bindings.
  "services": [
    { "binding": "BASH_CORE", "service": "nano-agent-bash-core" },
    // RH1 P1-06a — service binding to orchestrator-core for cross-worker
    // WS push (NanoSessionDO emits server frames via
    // OrchestratorCoreEntrypoint.forwardServerFrameToClient → User DO).
    { "binding": "ORCHESTRATOR_CORE", "service": "nano-agent-orchestrator-core" }
    // { "binding": "CONTEXT_CORE", "service": "nano-agent-context-core" },
    // { "binding": "FILESYSTEM_CORE", "service": "nano-agent-filesystem-core" }
  ],
  "d1_databases": [
    {
      "binding": "NANO_AGENT_DB",
      "database_name": "nano-agent-preview",
      "database_id": "71a4b089-93e0-4d8f-afb8-bc9356a97cfa"
    }
  ],
  // RH0 P0-C1 — KV/R2 binding first-declaration (placeholder ids).
  "kv_namespaces": [
    {
      "binding": "NANO_KV",
      "id": "f5de37a4139a480683368d39ca4bbb62"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NANO_R2",
      "bucket_name": "nano-agent-spike-do-storage-probe"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "env": {
    "preview": {
      "vars": {
        "ENVIRONMENT": "preview",
        "OWNER_TAG": "nano-agent",
        "WORKER_VERSION": "agent-core@preview",
        "TEAM_UUID": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
        "ORCHESTRATOR_PUBLIC_BASE_URL": "https://nano-agent-orchestrator-core-preview.haimang.workers.dev",
        "NANO_AGENT_LLM_CALL_LIMIT": "200",
        "NANO_AGENT_TOOL_CALL_LIMIT": "400",
        "NANO_AGENT_ALLOW_PREVIEW_TEAM_SEED": "true"
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "SESSION_DO",
            "class_name": "NanoSessionDO"
          }
        ]
      },
      "services": [
        { "binding": "BASH_CORE", "service": "nano-agent-bash-core-preview" },
        { "binding": "ORCHESTRATOR_CORE", "service": "nano-agent-orchestrator-core-preview" }
      ],
      "d1_databases": [
        {
          "binding": "NANO_AGENT_DB",
          "database_name": "nano-agent-preview",
          "database_id": "71a4b089-93e0-4d8f-afb8-bc9356a97cfa"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "NANO_KV",
          "id": "f5de37a4139a480683368d39ca4bbb62"
        }
      ],
      "r2_buckets": [
        {
          "binding": "NANO_R2",
          "bucket_name": "nano-agent-spike-do-storage-probe"
        }
      ],
      "ai": {
        "binding": "AI"
      }
    }
  }
}
