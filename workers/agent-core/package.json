{
  "name": "@haimang/agent-core-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "agent-core worker — absorbed runtime (P1.A: host / kernel / llm / hooks / eval)",
  "scripts": {
    "prebuild": "pnpm --filter @haimang/context-core-worker build",
    "pretest": "pnpm --filter @haimang/context-core-worker build",
    "pretypecheck": "pnpm --filter @haimang/context-core-worker build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy:preview": "pnpm build && wrangler deploy --env preview",
    "deploy:dry-run": "wrangler deploy --dry-run --env=\"\""
  },
  "dependencies": {
    "@haimang/context-core-worker": "workspace:*",
    "@haimang/nacp-core": "workspace:*",
    "@haimang/nacp-session": "workspace:*",
    "@nano-agent/workspace-context-artifacts": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@nano-agent/eval-observability": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.83.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "zod": ">=3.22.0"
  }
}
