{
  "name": "@haimang/context-core-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Pre-worker-matrix shell for context-core",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./context-api/append-initial-context-layer": {
      "types": "./dist/context-api/append-initial-context-layer.d.ts",
      "import": "./dist/context-api/append-initial-context-layer.js"
    }
  },
  "scripts": {
    "prepare:package-manifest": "node ../../scripts/generate-package-manifest.mjs --worker context-core --ts-module src/generated/package-manifest.ts",
    "prebuild": "pnpm run prepare:package-manifest",
    "build": "tsc",
    "pretypecheck": "pnpm run prepare:package-manifest",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run prepare:package-manifest",
    "test": "vitest run",
    "predeploy": "node ../../scripts/verify-published-packages.mjs",
    "predeploy:preview": "pnpm run predeploy",
    "deploy:preview": "pnpm run predeploy && pnpm build && wrangler deploy --env preview",
    "deploy:production": "pnpm run predeploy && pnpm build && wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run --env=\"\""
  },
  "dependencies": {
    "@haimang/nacp-core": "workspace:*",
    "@haimang/nacp-session": "workspace:*",
    "@nano-agent/storage-topology": "workspace:*",
    "@nano-agent/workspace-context-artifacts": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.83.0"
  }
}
