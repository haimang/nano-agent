{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nano-agent-orchestrator-core",
  "main": "dist/entrypoint.js",
  // ZX2 Phase 1 P1-02 (transport-profiles.md):
  // orchestrator-core 是唯一 public facade。显式开启 workers.dev 公网入口。
  // profile = facade-http-v1 + session-ws-v1 + health-probe.
  "workers_dev": true,
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  // Required deploy-time secrets:
  // - JWT_SIGNING_KEY_<kid> (for example JWT_SIGNING_KEY_v1)
  // - Optional legacy fallback: JWT_SECRET
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview",
    "OWNER_TAG": "nano-agent",
    "WORKER_VERSION": "orchestrator-core@preview",
    "TEAM_UUID": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
    "JWT_SIGNING_KID": "v1"
  },
  "d1_databases": [
    {
      "binding": "NANO_AGENT_DB",
      "database_name": "nano-agent-preview",
      // Shared `nano-agent-preview` D1 instance — same UUID across all 6 workers
      // so they read/write the same truth. Production deploys override per-env.
      "database_id": "71a4b089-93e0-4d8f-afb8-bc9356a97cfa",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ORCHESTRATOR_USER_DO",
        "class_name": "NanoOrchestratorUserDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["NanoOrchestratorUserDO"]
    }
  ],
  "services": [
    { "binding": "AGENT_CORE", "service": "nano-agent-agent-core" },
    { "binding": "ORCHESTRATOR_AUTH", "service": "nano-agent-orchestrator-auth" },
    { "binding": "BASH_CORE", "service": "nano-agent-bash-core" },
    { "binding": "CONTEXT_CORE", "service": "nano-agent-context-core" },
    { "binding": "FILESYSTEM_CORE", "service": "nano-agent-filesystem-core" }
  ],
  // RH0 P0-C1 — KV/R2 binding first-declaration (placeholder ids).
  // RH0 only declares; downstream phases (RH3 KV idempotency / RH4 R2 file
  // pipeline) actually consume. Placeholder ids point to existing
  // `nano-agent-spike-do-storage-*` resources discovered by P0-F1 Step 4/5.
  "kv_namespaces": [
    {
      "binding": "NANO_KV",
      "id": "f5de37a4139a480683368d39ca4bbb62"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NANO_R2",
      "bucket_name": "nano-agent-spike-do-storage-probe"
    }
  ],
  "env": {
    "preview": {
      "vars": {
        "ENVIRONMENT": "preview",
        "OWNER_TAG": "nano-agent",
        "WORKER_VERSION": "orchestrator-core@preview",
        "TEAM_UUID": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
        "JWT_SIGNING_KID": "v1"
      },
      "d1_databases": [
        {
          "binding": "NANO_AGENT_DB",
          "database_name": "nano-agent-preview",
          // Shared `nano-agent-preview` D1 instance — see top-of-file comment.
          "database_id": "71a4b089-93e0-4d8f-afb8-bc9356a97cfa",
          "migrations_dir": "migrations"
        }
      ],
      "services": [
        { "binding": "AGENT_CORE", "service": "nano-agent-agent-core-preview" },
        { "binding": "ORCHESTRATOR_AUTH", "service": "nano-agent-orchestrator-auth-preview" },
        { "binding": "BASH_CORE", "service": "nano-agent-bash-core-preview" },
        { "binding": "CONTEXT_CORE", "service": "nano-agent-context-core-preview" },
        { "binding": "FILESYSTEM_CORE", "service": "nano-agent-filesystem-core-preview" }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "ORCHESTRATOR_USER_DO",
            "class_name": "NanoOrchestratorUserDO"
          }
        ]
      },
      "kv_namespaces": [
        {
          "binding": "NANO_KV",
          "id": "f5de37a4139a480683368d39ca4bbb62"
        }
      ],
      "r2_buckets": [
        {
          "binding": "NANO_R2",
          "bucket_name": "nano-agent-spike-do-storage-probe"
        }
      ]
    }
  }
}
