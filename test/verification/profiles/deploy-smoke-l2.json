{
  "id": "deploy-smoke-l2",
  "label": "L2 real-boundary smoke (wrangler deploy + workers.dev smoke)",
  "tooling": "wrangler deploy + curl/openapi",
  "purpose": "Real cloud bindings + real provider golden path. Phase advancement gate.",
  "bindings": [
    {"name": "SESSION_DO", "kind": "durable_object", "class_name": "NanoSessionDO"},
    {"name": "R2_ARTIFACTS", "kind": "r2_bucket", "bucket_name": "nano-agent-artifacts-prod"},
    {"name": "KV_CONFIG", "kind": "kv_namespace", "id": "nano-agent-kv-config-prod"},
    {"name": "HOOK_WORKER", "kind": "service", "service": "nano-agent-fake-hook-worker"},
    {"name": "CAPABILITY_WORKER", "kind": "service", "service": "nano-agent-fake-capability-worker"}
  ],
  "secrets": [
    {"name": "OPENAI_API_KEY", "source": "wrangler secret put", "required": true, "note": "Q11: never .env"},
    {"name": "TEAM_UUID", "source": "wrangler secret put", "required": true}
  ],
  "compositionProfile": {"capability": "remote", "hooks": "remote", "provider": "local"},
  "providerGoldenPath": "openai-compatible / gpt-4.1-nano",
  "verdictTrigger": "phase advancement gate",
  "ladderPosition": "L2",
  "secretInjection": "wrangler secret put",
  "smokePromptContract": "Reply with exactly: OK",
  "smokeAssertionContract": "response.status === 'ok' && response.output.length > 0"
}
