{
  "name": "@nano-agent/storage-topology",
  "version": "2.0.0",
  "type": "module",
  "description": "Storage Topology — hot/warm/cold semantics, key/ref builders, provisional placement",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
