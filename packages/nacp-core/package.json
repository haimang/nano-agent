{
  "name": "@haimang/nacp-core",
  "version": "1.4.0",
  "type": "module",
  "description": "NACP-Core — Nano-Agent Communication Protocol internal envelope layer",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./messages/*": {
      "types": "./dist/messages/*.d.ts",
      "import": "./dist/messages/*.js"
    },
    "./tenancy": {
      "types": "./dist/tenancy/index.d.ts",
      "import": "./dist/tenancy/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./evidence": {
      "types": "./dist/evidence/index.d.ts",
      "import": "./dist/evidence/index.js"
    },
    "./hooks-catalog": {
      "types": "./dist/hooks-catalog/index.d.ts",
      "import": "./dist/hooks-catalog/index.js"
    },
    "./storage-law": {
      "types": "./dist/storage-law/index.d.ts",
      "import": "./dist/storage-law/index.js"
    },
    "./observability": {
      "types": "./dist/observability/envelope.d.ts",
      "import": "./dist/observability/envelope.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/integration/",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "lint:tenant-io": "bash scripts/lint-tenant-io.sh",
    "build:schema": "tsx scripts/export-schema.ts",
    "build:docs": "tsx scripts/gen-registry-doc.ts"
  },
  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haimang/nano-agent.git",
    "directory": "packages/nacp-core"
  },
  "license": "UNLICENSED"
}
