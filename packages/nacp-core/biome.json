{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "nursery": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {}
          }
        }
      }
    }
  },
  "overrides": [
    {
      "include": ["src/**/*.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {}
              }
            }
          }
        }
      }
    },
    {
      "include": ["src/tenancy/scoped-io.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "off"
            }
          }
        }
      }
    }
  ]
}
