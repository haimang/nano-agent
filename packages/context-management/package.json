  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nano-agent/nano-agent.git",
    "directory": "packages/context-management"
  },
