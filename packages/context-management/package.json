{
  "name": "@nano-agent/context-management",
  "version": "0.1.0",
  "type": "module",
  "description": "Context-Management — budget policy, async compact lifecycle, inspector facade",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./budget": {
      "types": "./dist/budget/index.d.ts",
      "import": "./dist/budget/index.js"
    },
    "./async-compact": {
      "types": "./dist/async-compact/index.d.ts",
      "import": "./dist/async-compact/index.js"
    },
    "./inspector-facade": {
      "types": "./dist/inspector-facade/index.d.ts",
      "import": "./dist/inspector-facade/index.js"
    }
