{
  // Wrangler config for the Session DO Runtime.
  //
  // The "default" config below is the L1 (`wrangler dev --remote`)
  // baseline. It declares every v1 binding slot owned by the A5 binding
  // catalog so the deploy-shaped boundary can be exercised without
  // editing this file per-run. The L2 (`wrangler deploy`) profile lives
  // under the env.deploy_smoke override.
  //
  // - `main` points at the compiled Worker entry — `pnpm build`
  //   produces `dist/worker.js` from `src/worker.ts`.
  // - The fake hook / capability / fake-provider service bindings
  //   reference companion workers under `wranglers/` (see A6 P2-02
  //   smoke-runner README). When those workers are absent, the runtime
  //   degrades gracefully to the local profile (`A5 readCompositionProfile`).
  // - `OPENAI_API_KEY` is NEVER committed; L1 reads `.dev.vars`,
  //   L2 reads `wrangler secret put OPENAI_API_KEY`.
  "name": "nano-agent-session",
  "compatibility_date": "2024-12-01",
  "main": "dist/worker.js",
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSION_DO",
        "class_name": "NanoSessionDO"
      }
    ]
  },
  "services": [
    { "binding": "HOOK_WORKER", "service": "nano-agent-fake-hook-worker" },
    { "binding": "CAPABILITY_WORKER", "service": "nano-agent-fake-capability-worker" },
    { "binding": "FAKE_PROVIDER_WORKER", "service": "nano-agent-fake-provider-worker" }
  ],
  "kv_namespaces": [
    { "binding": "KV_CONFIG", "preview_id": "nano-agent-kv-config-dev" }
  ],
  "r2_buckets": [
    { "binding": "R2_ARTIFACTS", "preview_bucket_name": "nano-agent-artifacts-dev" }
  ],
  "vars": {
    "ENVIRONMENT": "remote-dev"
  },
  "env": {
    // L2 deploy-smoke profile — `wrangler deploy --env deploy_smoke`.
    // Real R2 + KV + provider key flow through this override; the fake
    // worker bindings are *kept* to preserve the cross-seam taxonomy
    // even in production-shaped runs (provider golden path is the only
    // seam that actually flips to real-cloud upstream).
    "deploy_smoke": {
      "vars": {
        "ENVIRONMENT": "deploy-smoke"
      },
      "kv_namespaces": [
        { "binding": "KV_CONFIG", "id": "nano-agent-kv-config-prod" }
      ],
      "r2_buckets": [
        { "binding": "R2_ARTIFACTS", "bucket_name": "nano-agent-artifacts-prod" }
      ]
    }
  }
}
