// spike-binding-pair-r2 worker-a (caller) — Round 2 integrated binding probe.
//
// Deployed SECOND (after worker-b-r2). Services binding references
// `nano-agent-spike-binding-pair-b-r2`.
{
  "name": "nano-agent-spike-binding-pair-a-r2",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  "vars": {
    "ENVIRONMENT": "spike-r2-integrated",
    "SPIKE_NAMESPACE": "spike-binding-pair-r2",
    "ROLE": "caller",
    "EXPIRATION_DATE": "2026-08-01",
    "OWNER_TAG": "nano-agent",
    "STAGE_TAG": "spike-r2"
  },

  "services": [
    { "binding": "WORKER_B", "service": "nano-agent-spike-binding-pair-b-r2" }
  ],

  "observability": {
    "enabled": true
  }
}
