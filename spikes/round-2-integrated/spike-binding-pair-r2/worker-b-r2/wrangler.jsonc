// spike-binding-pair-r2 worker-b (callee) — Round 2 integrated binding probe.
//
// Deployed FIRST (worker-a-r2 binds to this by name).
//
// Distinction vs. Round 1 worker-b:
//   - Owns the `BoundedEvalSink` for binding-F04 **true callback push
//     path** — worker-a pushes eval records here, worker-b accepts them,
//     and this worker exposes dedup / overflow disclosure as query routes
//     so the caller can verify the live wire contract.
//   - Keeps the slow / echo / header-dump / hook-dispatch handlers the
//     Round 1 worker-b had so binding-F01 / binding-F02 / binding-F03 /
//     hooks re-validation still work.
//
// 7 disciplines — Round 2 exception §7: IS allowed to import
// `@nano-agent/*`. This worker uses `@nano-agent/session-do-runtime`
// `BoundedEvalSink` as the true callback sink.
{
  "name": "nano-agent-spike-binding-pair-b-r2",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  "vars": {
    "ENVIRONMENT": "spike-r2-integrated",
    "SPIKE_NAMESPACE": "spike-binding-pair-r2",
    "ROLE": "callee",
    "EXPIRATION_DATE": "2026-08-01",
    "OWNER_TAG": "nano-agent",
    "STAGE_TAG": "spike-r2"
  },

  "observability": {
    "enabled": true
  },

  // Round-2 alias: see `spike-do-storage-r2/wrangler.jsonc` for rationale.
  "alias": {
    "@nano-agent/session-do-runtime": "../../../../packages/session-do-runtime/dist/index.js"
  }
}
