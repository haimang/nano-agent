/* pages/chat/index.wxss */
/* IDE 风格首页：左侧对话列表 + 右侧主区域 */

page {
  height: 100vh;
  overflow: hidden;
}

/* === 侧边栏 === */
.sidebar {
  width: 200rpx;
  background-color: #1a1a2e;
  color: #e2e8f0;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  border-right: 1rpx solid #334155;
}

.sidebar-header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #334155;
  flex-shrink: 0;
}

.sidebar-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #94a3b8;
}

.sidebar-action {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #252535;
  border-radius: 8rpx;
}

.action-icon {
  font-size: 32rpx;
  color: #e2e8f0;
  font-weight: 300;
}

.sidebar-content {
  flex: 1;
  overflow: hidden;
}

.new-chat-btn {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin: 16rpx;
  background-color: #252535;
  border-radius: 12rpx;
  border: 1rpx solid #334155;
}

.new-chat-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.new-chat-text {
  font-size: 24rpx;
  color: #e2e8f0;
}

.chat-list {
  padding: 0 12rpx;
}

.list-section-title {
  font-size: 20rpx;
  color: #64748b;
  padding: 16rpx 16rpx 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
  border-left: 3rpx solid transparent;
}

.chat-item.active {
  background-color: #252535;
  border-left-color: #FE564D;
}

.chat-item-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.chat-item-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.chat-item-title {
  display: block;
  font-size: 24rpx;
  color: #e2e8f0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-item-time {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.empty-list {
  padding: 40rpx 20rpx;
  text-align: center;
}

.empty-text {
  font-size: 22rpx;
  color: #64748b;
}

.sidebar-footer {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-top: 1rpx solid #334155;
  flex-shrink: 0;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #264653;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.user-name {
  font-size: 24rpx;
  color: #94a3b8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* === 主区域 === */
.main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background-color: #f4f4f4;
}

.main-toolbar {
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  flex-shrink: 0;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 20rpx;
}

.status-indicator.online {
  background-color: #e1f3d8;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
}

.status-indicator.online .status-dot {
  background-color: #07c160;
}

.status-text {
  font-size: 22rpx;
  color: #999;
}

.status-indicator.online .status-text {
  color: #07c160;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.btn-icon {
  font-size: 28rpx;
}

.main-content {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

/* === 欢迎卡片 === */
.welcome-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.welcome-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.welcome-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

/* === 功能区域 === */
.feature-section {
  margin-bottom: 24rpx;
}

.feature-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 6rpx;
}

.feature-card {
  flex: 1;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.feature-icon {
  font-size: 48rpx;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* === 统计区域 === */
.stats-section {
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
  padding: 0 6rpx;
}

.stat-card {
  flex: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #264653;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}
