.page {
  padding: 24rpx;
}

.card {
  background: #111827;
  border: 1px solid #334155;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-weight: 700;
  margin-bottom: 12rpx;
}

input,
textarea {
  background: #020617;
  border: 1px solid #475569;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #e2e8f0;
  margin: 12rpx 0;
  padding: 16rpx;
  width: 100%;
}

textarea {
  min-height: 160rpx;
}

.row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

button {
  background: #38bdf8;
  color: #082f49;
  font-weight: 700;
  margin: 0;
}

.log {
  background: #020617;
  border: 1px solid #1e293b;
  border-radius: 12rpx;
  color: #e2e8f0;
  display: block;
  margin-top: 12rpx;
  padding: 12rpx;
  white-space: pre-wrap;
}
