/* pages/session/index.wxss */
/* IDE 风格对话页 */

page {
  height: 100vh;
  overflow: hidden;
}

.session-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f4f4f4;
}

/* === 顶部工具栏 === */
.session-toolbar {
  height: 88rpx;
  background-color: #1a1a2e;
  color: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #334155;
  flex-shrink: 0;
}

.toolbar-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
}

.back-icon {
  font-size: 40rpx;
  font-weight: 300;
  color: #94a3b8;
}

.back-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.toolbar-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.session-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e2e8f0;
}

.connection-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.status-pulse {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #f56c6c;
}

.connection-status.online .status-pulse {
  background-color: #07c160;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}

.status-label {
  font-size: 20rpx;
  color: #64748b;
}

.connection-status.online .status-label {
  color: #07c160;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  min-width: 120rpx;
  justify-content: flex-end;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #252535;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 28rpx;
}

/* === 消息区域 === */
.message-area {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.system-welcome {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.welcome-box {
  text-align: center;
  max-width: 600rpx;
}

.welcome-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.welcome-heading {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.welcome-sub {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.welcome-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.message-wrapper {
  margin-bottom: 8rpx;
}

/* === 底部输入面板 === */
.input-panel {
  background-color: #ffffff;
  border-top: 1rpx solid #e0e0e0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ide-input {
  flex: 1;
  height: 80rpx;
  background-color: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  font-family: inherit;
  box-sizing: border-box;
}

.ide-input:focus {
  border-color: #264653;
}

.send-button {
  width: 80rpx;
  height: 80rpx;
  background-color: #264653;
  color: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
}

.send-button::after {
  border: none;
}

.send-button.sending {
  opacity: 0.7;
}

.send-icon {
  font-size: 32rpx;
}

.send-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.input-hints {
  margin-top: 8rpx;
  text-align: center;
}

.hint-text {
  font-size: 20rpx;
  color: #999;
}

/* === 日志覆盖层 === */
.log-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 26, 46, 0.95);
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.log-header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #334155;
}

.log-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e2e8f0;
}

.log-close-btn {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 16rpx;
}
