/* components/skeleton-loader/index.wxss */
.skeleton-container {
  padding: 24rpx;
}

.skeleton-item {
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-title {
  height: 40rpx;
  width: 60%;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 32rpx;
  width: 100%;
}

.skeleton-line.short {
  width: 40%;
}

@keyframes shimmer {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}
