/* components/markdown-display/index.wxss */
.markdown-container {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.md-p {
  margin-bottom: 16rpx;
}

.md-h1 {
  font-size: 40rpx;
  font-weight: 600;
  margin: 32rpx 0 16rpx;
  color: #333;
}

.md-h2 {
  font-size: 36rpx;
  font-weight: 600;
  margin: 28rpx 0 14rpx;
  color: #333;
}

.md-h3 {
  font-size: 32rpx;
  font-weight: 600;
  margin: 24rpx 0 12rpx;
  color: #333;
}

.md-blockquote {
  border-left: 6rpx solid #13227a;
  padding-left: 20rpx;
  margin: 16rpx 0;
  color: #666;
  background-color: #f8f9fa;
  padding: 16rpx 16rpx 16rpx 24rpx;
  border-radius: 0 8rpx 8rpx 0;
}

.md-list {
  margin: 16rpx 0;
  padding-left: 16rpx;
}

.md-li {
  margin-bottom: 8rpx;
  display: flex;
  align-items: flex-start;
}

.md-li-marker {
  margin-right: 12rpx;
  color: #13227a;
  font-weight: 500;
  min-width: 32rpx;
}

.md-strong {
  font-weight: 600;
  color: #13227a;
}

.md-em {
  font-style: italic;
  color: #666;
}

.md-img {
  max-width: 100%;
  border-radius: 12rpx;
  margin: 16rpx 0;
}

.md-text {
  word-break: break-all;
}
